---
import Layout from "../layouts/Layout.astro";

const services = [
  {
    title: "Herrenhaarschnitt",
    description: "Präziser Schnitt nach aktuellen Trends oder klassischem Stil – ganz nach deinen Wünschen. Inklusive Waschen und Styling.",
    price: "ab 25 €",
    duration: "ca. 45 Min.",
    icon: "M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"
  },
  {
    title: "Bartschnitt & Pflege",
    description: "Formgebung und Pflege deines Bartes mit heißem Handtuch, Ölen und perfektem Kontur-Finish.",
    price: "ab 18 €",
    duration: "ca. 30 Min.",
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
  },
  {
    title: "Klassische Rasur",
    description: "Die traditionelle Nassrasur mit Rasiermesser, heißem Handtuch und hochwertigen Pflegeprodukten.",
    price: "ab 22 €",
    duration: "ca. 35 Min.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    title: "Premium-Paket",
    description: "Das Komplettpaket: Haarschnitt, Bartschnitt und klassische Rasur – für den Mann, der das Beste verdient.",
    price: "ab 55 €",
    duration: "ca. 90 Min.",
    icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
  },
  {
    title: "Kopfmassage",
    description: "Entspannende Massage mit ätherischen Ölen – die perfekte Ergänzung zu jedem Schnitt.",
    price: "ab 12 €",
    duration: "ca. 15 Min.",
    icon: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    title: "Seniorenschnitt",
    description: "Gepflegter Kurzhaarschnitt für unsere erfahrenen Herren – mit Ruhe, Geduld und Respekt.",
    price: "ab 20 €",
    duration: "ca. 40 Min.",
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
  }
];

const galleryImages = [
  { alt: "Barbier bei der Arbeit", color: "bg-soran-light" },
  { alt: "Haarschnitt Detail", color: "bg-soran" },
  { alt: "Bartpflege", color: "bg-soran-light" },
  { alt: "Klassische Rasur", color: "bg-soran" },
  { alt: "Shop Ambiente", color: "bg-soran-light" },
  { alt: "Premium-Service", color: "bg-soran" }
];
---

<Layout>
  <!-- Hero Section -->
  <section id="home" class="relative min-h-[100svh] w-full flex items-center justify-center overflow-hidden">
    <!-- Background Image -->
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/hero-barber.jpg" 
        alt="Barbier bei der Arbeit" 
        class="w-full h-full object-cover scale-110"
        id="hero-img"
      />
      <div class="absolute inset-0 bg-soran-dark/70"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-soran-dark/60 via-soran-dark/40 to-soran-dark"></div>
    </div>

    <!-- Decorative Pattern -->
    <div class="absolute inset-0 bg-pattern opacity-30 z-10 pointer-events-none"></div>

    <div class="relative z-20 text-center px-4 max-w-6xl">
      <div class="reveal-up">
        <div class="h-20 w-20 rounded-full bg-soran-gold flex items-center justify-center mx-auto mb-6 shadow-[0_0_40px_rgba(201,169,98,0.3)]">
          <span class="text-soran-dark font-black text-4xl">S</span>
        </div>
      </div>

      <div class="reveal-up delay-100">
        <span class="inline-block border border-soran-gold/30 text-soran-gold text-xs md:text-sm font-bold px-4 py-2 rounded-full uppercase tracking-[0.2em] backdrop-blur-sm bg-black/20">
          Traditionelle Barbierkunst
        </span>
      </div>

      <h1 class="reveal-up delay-200 text-[2.5rem] sm:text-5xl md:text-7xl lg:text-8xl font-black text-white mb-6 leading-[1.05] tracking-tight mt-4">
        SORAN<br />
        <span class="text-gradient">Barbier</span>
      </h1>

      <p class="reveal-up delay-300 text-sm sm:text-base md:text-xl text-gray-300 mb-10 sm:mb-12 max-w-2xl mx-auto font-light leading-relaxed">
        Präzise Schnitte, gepflegte Bärte und die klassische Rasur – mit Stil und Leidenschaft in Dessau-Roßlau.
      </p>

      <div class="reveal-up delay-400 flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="#kontakt" class="btn-primary">
          <span>Jetzt Termin buchen</span>
        </a>
        <a href="#leistungen" class="btn-outline">
          Unsere Leistungen
        </a>
      </div>
    </div>

    <a href="#leistungen" class="absolute bottom-5 sm:bottom-8 left-1/2 -translate-x-1/2 z-20 text-soran-gold/80 hover:text-soran-gold transition-colors animate-bounce" aria-label="Zu den Leistungen scrollen">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
    </a>
  </section>

  <!-- Services Section -->
  <section id="leistungen" class="py-16 md:py-28 bg-soran relative">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10 md:mb-16">
        <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Was wir anbieten</span>
        <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-6xl font-black text-white mb-4 tracking-tight leading-tight">
          Unsere <span class="text-gradient">Leistungen</span>
        </h2>
        <p class="reveal-up delay-200 text-gray-400 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-relaxed">
          Von der klassischen Rasur bis zum modernen Fade – bei SORAN bekommst du die Pflege, die du verdienst.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {services.map((service, i) => (
          <article class={`reveal-up group bg-soran-light/50 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-soran-gold/10 hover:border-soran-gold/30 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(201,169,98,0.1)]`} style={`animation-delay: ${i * 100}ms`}>
            <div class="w-14 h-14 rounded-xl bg-soran-gold/10 flex items-center justify-center mb-5 group-hover:bg-soran-gold/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-soran-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 text-white group-hover:text-soran-gold transition-colors">{service.title}</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">{service.description}</p>
            <div class="flex items-center justify-between pt-4 border-t border-soran-gold/10">
              <span class="text-soran-gold font-black text-lg">{service.price}</span>
              <span class="text-gray-500 text-sm">{service.duration}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="ueber-uns" class="py-16 md:py-28 bg-soran-dark relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-soran-gold/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-soran-gold/5 rounded-full blur-3xl"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="reveal-left relative">
          <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl relative z-10 bg-soran-light">
            <img 
              src="/images/hero-barber.jpg" 
              alt="SORAN Barbier Shop" 
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-soran-gold/10 rounded-full blur-3xl -z-0"></div>
          <div class="reveal-up absolute -bottom-6 -left-6 bg-soran-light border border-soran-gold/20 p-6 rounded-2xl shadow-2xl z-20 hidden md:block" style="animation-delay: 300ms">
            <p class="text-4xl font-black text-soran-gold">10+</p>
            <p class="text-gray-400 font-bold uppercase text-xs tracking-wider mt-1">Jahre Erfahrung</p>
          </div>
        </div>

        <div class="text-center lg:text-left">
          <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Unsere Geschichte</span>
          <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-5xl font-black text-white mb-6 md:mb-8 tracking-tight leading-tight">
            Wo <span class="text-gradient">Tradition</span><br/>auf Stil trifft
          </h2>
          <div class="space-y-5 md:space-y-6 text-gray-400 text-sm sm:text-base md:text-lg leading-relaxed">
            <p class="reveal-up delay-200">
              SORAN steht für traditionelle Barbierkunst mit modernem Anspruch. In unserem Laden in Dessau vereinen wir die alten Techniken der klassischen Barbierkunst mit aktuellen Trends.
            </p>
            <p class="reveal-up delay-300">
              Jeder Schnitt ist ein Kunstwerk – egal ob klassischer Gentleman-Style, scharfer Fade oder gepflegter Vollbart. Wir nehmen uns Zeit für dich und deinen Look.
            </p>
            <p class="reveal-up delay-400">
              Bei uns geht es nicht nur um Haare. Es geht um das Erlebnis, die Atmosphäre und das Gefühl, als Mann perfekt gepflegt zu sein.
            </p>
          </div>

          <div class="mt-8 md:mt-10 grid grid-cols-2 sm:grid-cols-3 gap-4 md:gap-6">
            <div class="reveal-up delay-200 bg-soran-light/50 p-5 rounded-2xl border border-soran-gold/10 text-center">
              <p class="font-black text-2xl text-soran-gold">1000+</p>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-1">Zufriedene Kunden</p>
            </div>
            <div class="reveal-up delay-300 bg-soran-light/50 p-5 rounded-2xl border border-soran-gold/10 text-center">
              <p class="font-black text-2xl text-soran-gold">10+</p>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-1">Jahre Erfahrung</p>
            </div>
            <div class="reveal-up delay-400 bg-soran-light/50 p-5 rounded-2xl border border-soran-gold/10 text-center col-span-2 sm:col-span-1">
              <p class="font-black text-2xl text-soran-gold">★★★★★</p>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-1">Google Bewertung</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Preview Section -->
  <section id="galerie" class="py-16 md:py-28 bg-soran relative">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10 md:mb-16">
        <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Einblicke</span>
        <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-6xl font-black text-white mb-4 tracking-tight leading-tight">
          Unsere <span class="text-gradient">Galerie</span>
        </h2>
        <p class="reveal-up delay-200 text-gray-400 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-relaxed">
          Eindrücke aus unserem Shop – Atmosphäre, Details und die Kunst des Barbierens.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {galleryImages.map((img, i) => (
          <div class:list={[
            "reveal-up relative aspect-square rounded-2xl overflow-hidden group cursor-pointer",
            i === 0 || i === 3 ? "md:col-span-2 md:row-span-2" : ""
          ]}>
            <div class:list={["w-full h-full flex items-center justify-center transition-transform duration-700 group-hover:scale-110", img.color]}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-soran-gold/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-soran-dark/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4 md:p-6">
              <span class="text-white font-bold text-sm md:text-base">{img.alt}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-16 md:py-28 bg-soran-dark relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-soran-gold/5 rounded-full blur-3xl"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10 md:mb-16">
        <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Das sagen unsere Kunden</span>
        <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-5xl font-black text-white tracking-tight leading-tight">
          <span class="text-gradient">Bewertungen</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {[
          { name: "Markus K.", text: "Endlich ein Barbier, der versteht, was ich will. Der Fade ist perfekt und die Atmosphäre im Laden ist erstklassig.", stars: 5 },
          { name: "Thomas W.", text: "Die klassische Rasur ist ein Erlebnis. Heißes Handtuch, gutes Gespräch und ein Baby-glatter Ansatz – besser geht's nicht.", stars: 5 },
          { name: "David S.", text: "Mein Bart hat noch nie so gut ausgesehen. Soran nimmt sich Zeit und berät ehrlich. Seitdem fahre ich extra aus Roßlau nach Dessau.", stars: 5 }
        ].map((review, i) => (
          <div class={`reveal-up bg-soran-light/30 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-soran-gold/10 hover:border-soran-gold/20 transition-all duration-300 hover:-translate-y-1`} style={`animation-delay: ${i * 150}ms`}>
            <div class="flex gap-1 mb-4">
              {Array.from({ length: review.stars }).map(() => (
                <svg class="w-5 h-5 text-soran-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-300 text-sm leading-relaxed mb-4">"{review.text}"</p>
            <p class="text-soran-gold font-bold text-sm">{review.name}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-soran relative overflow-hidden">
    <div class="absolute inset-0 bg-pattern opacity-50"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-soran-gold/5 rounded-full blur-3xl"></div>
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center">
      <h2 class="reveal-up text-2xl sm:text-4xl md:text-5xl font-black text-white mb-6 md:mb-8 tracking-tight">
        Bereit für einen <span class="text-gradient">neuen Look?</span>
      </h2>
      <p class="reveal-up delay-100 text-gray-400 text-sm sm:text-base md:text-xl mb-8 md:mb-12 max-w-2xl mx-auto font-medium leading-relaxed">
        Buche jetzt deinen Termin und erlebe die traditionelle Barbierkunst in Dessau.
      </p>
      <div class="reveal-up delay-200">
        <a href="#kontakt" class="btn-primary inline-flex">
          Termin vereinbaren
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="kontakt" class="py-16 md:py-28 bg-soran-dark relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
        <div class="text-center lg:text-left">
          <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Kontakt</span>
          <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-5xl font-black text-white mb-6 tracking-tight">Besuch uns in Dessau</h2>
          <p class="reveal-up delay-200 text-gray-400 text-sm sm:text-base md:text-lg mb-8 md:mb-12 leading-relaxed">
            Reserviere deinen Termin oder schau einfach vorbei. Wir freuen uns auf dich!
          </p>

          <div class="space-y-6 sm:space-y-8">
            <div class="reveal-up delay-300 flex flex-col sm:flex-row items-center gap-3 sm:gap-6 group">
              <div class="bg-soran-light p-4 rounded-2xl group-hover:bg-soran-gold/20 transition-colors duration-300 border border-soran-gold/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-soran-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <p class="text-gray-500 font-bold uppercase text-xs tracking-widest mb-1">Adresse</p>
                <p class="text-base sm:text-xl font-bold text-white">Zerbster Straße 12</p>
                <p class="text-gray-400 text-sm">06844 Dessau-Roßlau</p>
              </div>
            </div>

            <div class="reveal-up delay-400 flex flex-col sm:flex-row items-center gap-3 sm:gap-6 group">
              <div class="bg-soran-light p-4 rounded-2xl group-hover:bg-soran-gold/20 transition-colors duration-300 border border-soran-gold/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-soran-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <p class="text-gray-500 font-bold uppercase text-xs tracking-widest mb-1">Telefon</p>
                <p class="text-base sm:text-xl font-bold text-white">0340 - 12345678</p>
              </div>
            </div>

            <div class="reveal-up delay-500 flex flex-col sm:flex-row items-center gap-3 sm:gap-6 group">
              <div class="bg-soran-light p-4 rounded-2xl group-hover:bg-soran-gold/20 transition-colors duration-300 border border-soran-gold/10">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-soran-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              </div>
              <div>
                <p class="text-gray-500 font-bold uppercase text-xs tracking-widest mb-1">Öffnungszeiten</p>
                <p class="text-base sm:text-xl font-bold text-white">Mo–Fr: 09:00 – 18:00</p>
                <p class="text-gray-400 text-sm">Sa: 09:00 – 14:00</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="reveal-right bg-soran-light/50 backdrop-blur-sm rounded-3xl p-6 sm:p-8 md:p-10 border border-soran-gold/10">
          <h3 class="text-xl sm:text-2xl font-black text-white mb-6">Termin anfragen</h3>
          <form class="space-y-4" action="#" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Name</label>
                <input type="text" id="name" name="name" required class="w-full bg-soran-dark border border-soran-gold/20 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-soran-gold/50 focus:ring-1 focus:ring-soran-gold/50 transition-colors" placeholder="Max Mustermann" />
              </div>
              <div>
                <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Telefon</label>
                <input type="tel" id="phone" name="phone" class="w-full bg-soran-dark border border-soran-gold/20 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-soran-gold/50 focus:ring-1 focus:ring-soran-gold/50 transition-colors" placeholder="0176 / ..." />
              </div>
            </div>
            <div>
              <label for="email" class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">E-Mail</label>
