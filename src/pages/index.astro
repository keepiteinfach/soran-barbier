---
import Layout from "../layouts/Layout.astro";
import LogoMark from "../components/LogoMark.astro";

export const prerender = true;

const services = [
  {
    titleDe: "Herrenhaarschnitt",
    titleAr: "قص الشعر للرجال",
    descDe: "Präziser Schnitt nach aktuellen Trends oder klassischem Stil – ganz nach deinen Wünschen. Inklusive Waschen und Styling.",
    descAr: "قص دقيق يتبع أحدث الصيحات أو الأسلوب الكلاسيكي – حسب رغبتك. يشمل الغسيل والتصفيف.",
    price: "ab 25 €",
    durationDe: "ca. 45 Min.",
    durationAr: "حوالي 45 دقيقة",
    icon: "M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"
  },
  {
    titleDe: "Bartschnitt & Pflege",
    titleAr: "قص وتصفيف اللحية",
    descDe: "Formgebung und Pflege deines Bartes mit heißem Handtuch, Ölen und perfektem Kontur-Finish.",
    descAr: "تشكيل وعناية بلحيتك بالمنشفة الساخنة والزيوت واللمسة النهائية المثالية.",
    price: "ab 18 €",
    durationDe: "ca. 30 Min.",
    durationAr: "حوالي 30 دقيقة",
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
  },
  {
    titleDe: "Klassische Rasur",
    titleAr: "الحلاقة الكلاسيكية",
    descDe: "Die traditionelle Nassrasur mit Rasiermesser, heißem Handtuch und hochwertigen Pflegeprodukten.",
    descAr: "الحلاقة التقليدية بالشفرة والمنشفة الساخنة ومنتجات العناية الفاخرة.",
    price: "ab 22 €",
    durationDe: "ca. 35 Min.",
    durationAr: "حوالي 35 دقيقة",
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    titleDe: "Premium-Paket",
    titleAr: "الباقة المميزة",
    descDe: "Das Komplettpaket: Haarschnitt, Bartschnitt und klassische Rasur – für den Mann, der das Beste verdient.",
    descAr: "الباقة الشاملة: قص الشعر وتصفيف اللحية والحلاقة الكلاسيكية – للرجل الذي يستحق الأفضل.",
    price: "ab 55 €",
    durationDe: "ca. 90 Min.",
    durationAr: "حوالي 90 دقيقة",
    icon: "M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
  },
  {
    titleDe: "Kopfmassage",
    titleAr: "تدليك الرأس",
    descDe: "Entspannende Massage mit ätherischen Ölen – die perfekte Ergänzung zu jedem Schnitt.",
    descAr: "تدليك مريح بالزيوت العطرية – الإضافة المثالية لكل قصة شعر.",
    price: "ab 12 €",
    durationDe: "ca. 15 Min.",
    durationAr: "حوالي 15 دقيقة",
    icon: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
  },
  {
    titleDe: "Seniorenschnitt",
    titleAr: "قص الشعر للكبار",
    descDe: "Gepflegter Kurzhaarschnitt für unsere erfahrenen Herren – mit Ruhe, Geduld und Respekt.",
    descAr: "قصة شعر أنيقة لسادتنا الأكبر سنًا – بهدوء وصبر واحترام.",
    price: "ab 20 €",
    durationDe: "ca. 40 Min.",
    durationAr: "حوالي 40 دقيقة",
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
  }
];

const galleryImages = [
  { altDe: "Barbier bei der Arbeit", altAr: "الحلاق أثناء العمل", color: "bg-soran-light" },
  { altDe: "Haarschnitt Detail", altAr: "تفاصيل قص الشعر", color: "bg-soran" },
  { altDe: "Bartpflege", altAr: "عناية اللحية", color: "bg-soran-light" },
  { altDe: "Klassische Rasur", altAr: "الحلاقة الكلاسيكية", color: "bg-soran" },
  { altDe: "Shop Ambiente", altAr: "أجواء الصالون", color: "bg-soran-light" },
  { altDe: "Premium-Service", altAr: "خدمة مميزة", color: "bg-soran" }
];

const testimonials = [
  { name: "Markus K.", textDe: "Endlich ein Barbier, der versteht, was ich will. Der Fade ist perfekt und die Atmosphäre im Laden ist erstklassig.", textAr: "أخيرًا حلاق يفهم ما أريد. الفيد مثالي وأجواء المحل رائعة.", stars: 5 },
  { name: "Thomas W.", textDe: "Die klassische Rasur ist ein Erlebnis. Heißes Handtuch, gutes Gespräch und ein Baby-glatter Ansatz – besser geht's nicht.", textAr: "الحلاقة الكلاسيكية تجربة رائعة. المنشفة الساخنة، الحديث الممتع، والنتيجة ناعمة كالحرير – لا يمكن أن يكون أفضل.", stars: 5 },
  { name: "David S.", textDe: "Mein Bart hat noch nie so gut ausgesehen. Soran nimmt sich Zeit und berät ehrlich. Seitdem fahre ich extra aus Roßlau nach Dessau.", textAr: "لم تبدو لحيتي بهذا الجمال من قبل. سوران يأخذ وقته وينصح بصدق. منذ ذلك الحين أقطع الطريق من روسلو إلى ديساو.", stars: 5 }
];
---

<Layout>
  <!-- Hero Section -->
  <section id="home" class="relative min-h-[100svh] w-full flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img 
        src="/images/hero-barber.jpg" 
        alt="Barbier bei der Arbeit" 
        class="w-full h-full object-cover scale-110"
        id="hero-img"
      />
      <div class="absolute inset-0 bg-soran-dark/70"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-soran-dark/60 via-soran-dark/40 to-soran-dark"></div>
    </div>

    <div class="absolute inset-0 bg-pattern opacity-30 z-10 pointer-events-none"></div>

    <div class="relative z-20 text-center px-4 max-w-6xl">
      <div class="reveal-up">
        <LogoMark class="h-20 w-20 mx-auto mb-6 drop-shadow-[0_0_40px_rgba(201,169,98,0.3)]" />
      </div>

      <div class="reveal-up delay-100">
        <span class="inline-block border border-soran-gold/30 text-soran-gold text-xs md:text-sm font-bold px-4 py-2 rounded-full uppercase tracking-[0.2em] backdrop-blur-sm bg-black/20">
          <span data-lang="de">Traditionelle Barbierkunst</span>
          <span data-lang="ar" class="hidden" dir="rtl">فن الحلاقة التقليدي</span>
        </span>
      </div>

      <h1 class="reveal-up delay-200 text-[2.5rem] sm:text-5xl md:text-7xl lg:text-8xl font-black text-white mb-6 leading-[1.05] tracking-tight mt-4">
        SORAN<br />
        <span class="text-gradient">
          <span data-lang="de">Barbier</span>
          <span data-lang="ar" class="hidden" dir="rtl">صالون الحلاقة</span>
        </span>
      </h1>

      <p class="reveal-up delay-300 text-sm sm:text-base md:text-xl text-gray-300 mb-10 sm:mb-12 max-w-2xl mx-auto font-light leading-relaxed">
        <span data-lang="de">Präzise Schnitte, gepflegte Bärte und die klassische Rasur – mit Stil und Leidenschaft in Dessau-Roßlau.</span>
        <span data-lang="ar" class="hidden" dir="rtl">قصات دقيقة، لحى مهذبة، وحلاقة كلاسيكية – بأسلوب وشغف في ديساو-روسلاو.</span>
      </p>

      <div class="reveal-up delay-400 flex flex-col sm:flex-row justify-center items-center gap-4">
        <a href="#kontakt" class="btn-primary">
          <span data-lang="de">Jetzt Termin buchen</span>
          <span data-lang="ar" class="hidden" dir="rtl">احجز موعدك الآن</span>
        </a>
        <a href="#leistungen" class="btn-outline">
          <span data-lang="de">Unsere Leistungen</span>
          <span data-lang="ar" class="hidden" dir="rtl">خدماتنا</span>
        </a>
      </div>
    </div>

    <a href="#leistungen" class="absolute bottom-5 sm:bottom-8 left-1/2 -translate-x-1/2 z-20 text-soran-gold/80 hover:text-soran-gold transition-colors animate-bounce" aria-label="Scroll down">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
    </a>
  </section>

  <!-- Services Section -->
  <section id="leistungen" class="py-16 md:py-28 bg-soran relative">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10 md:mb-16">
        <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">
          <span data-lang="de">Was wir anbieten</span>
          <span data-lang="ar" class="hidden" dir="rtl">ما نقدمه</span>
        </span>
        <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-6xl font-black text-white mb-4 tracking-tight leading-tight">
          <span data-lang="de">Unsere <span class="text-gradient">Leistungen</span></span>
          <span data-lang="ar" class="hidden" dir="rtl"><span class="text-gradient">خدماتنا</span></span>
        </h2>
        <p class="reveal-up delay-200 text-gray-400 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-relaxed">
          <span data-lang="de">Von der klassischen Rasur bis zum modernen Fade – bei SORAN bekommst du die Pflege, die du verdienst.</span>
          <span data-lang="ar" class="hidden" dir="rtl">من الحلاقة الكلاسيكية إلى الفيد العصري – في سوران تحصل على العناية التي تستحقها.</span>
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {services.map((service, i) => (
          <article class="reveal-up group bg-soran-light/50 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-soran-gold/10 hover:border-soran-gold/30 transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(201,169,98,0.1)]">
            <div class="w-14 h-14 rounded-xl bg-soran-gold/10 flex items-center justify-center mb-5 group-hover:bg-soran-gold/20 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-soran-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={service.icon} />
              </svg>
            </div>
            <h3 class="text-lg sm:text-xl font-bold mb-2 text-white group-hover:text-soran-gold transition-colors">
              <span data-lang="de">{service.titleDe}</span>
              <span data-lang="ar" class="hidden" dir="rtl">{service.titleAr}</span>
            </h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-4">
              <span data-lang="de">{service.descDe}</span>
              <span data-lang="ar" class="hidden" dir="rtl">{service.descAr}</span>
            </p>
            <div class="flex items-center justify-between pt-4 border-t border-soran-gold/10">
              <span class="text-soran-gold font-black text-lg">{service.price}</span>
              <span class="text-gray-500 text-sm">
                <span data-lang="de">{service.durationDe}</span>
                <span data-lang="ar" class="hidden" dir="rtl">{service.durationAr}</span>
              </span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="ueber-uns" class="py-16 md:py-28 bg-soran-dark relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-soran-gold/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-soran-gold/5 rounded-full blur-3xl"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div class="reveal-left relative">
          <div class="aspect-[4/3] rounded-3xl overflow-hidden shadow-2xl relative z-10 bg-soran-light">
            <img 
              src="/images/hero-barber.jpg" 
              alt="SORAN Barbier Shop" 
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-soran-gold/10 rounded-full blur-3xl -z-0"></div>
          <div class="reveal-up absolute -bottom-6 -left-6 bg-soran-light border border-soran-gold/20 p-6 rounded-2xl shadow-2xl z-20 hidden md:block" style="animation-delay: 300ms">
            <p class="text-4xl font-black text-soran-gold">10+</p>
            <p class="text-gray-400 font-bold uppercase text-xs tracking-wider mt-1">
              <span data-lang="de">Jahre Erfahrung</span>
              <span data-lang="ar" class="hidden" dir="rtl">سنوات خبرة</span>
            </p>
          </div>
        </div>

        <div class="text-center lg:text-left">
          <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">
            <span data-lang="de">Unsere Geschichte</span>
            <span data-lang="ar" class="hidden" dir="rtl">قصتنا</span>
          </span>
          <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-5xl font-black text-white mb-6 md:mb-8 tracking-tight leading-tight">
            <span data-lang="de">Wo <span class="text-gradient">Tradition</span><br/>auf Stil trifft</span>
            <span data-lang="ar" class="hidden" dir="rtl">حيث تلتقي <span class="text-gradient">التقاليد</span><br/>بالأسلوب</span>
          </h2>
          <div class="space-y-5 md:space-y-6 text-gray-400 text-sm sm:text-base md:text-lg leading-relaxed">
            <p class="reveal-up delay-200">
              <span data-lang="de">SORAN steht für traditionelle Barbierkunst mit modernem Anspruch. In unserem Laden in Dessau vereinen wir die alten Techniken der klassischen Barbierkunst mit aktuellen Trends.</span>
              <span data-lang="ar" class="hidden" dir="rtl">سوران يمثل فن الحلاقة التقليدي بمعايير عصرية. في صالوننا بديساو نجمع بين تقنيات الحلاقة الكلاسيكية القديمة والصيحات الحديثة.</span>
            </p>
            <p class="reveal-up delay-300">
              <span data-lang="de">Jeder Schnitt ist ein Kunstwerk – egal ob klassischer Gentleman-Style, scharfer Fade oder gepflegter Vollbart. Wir nehmen uns Zeit für dich und deinen Look.</span>
              <span data-lang="ar" class="hidden" dir="rtl">كل قصة هي تحفة فنية – سواء كان الأسلوب الكلاسيكي الأنيق، الفيد الحاد، أو اللحية الكاملة المهذبة. نأخذ وقتاً لك ولإطلالتك.</span>
            </p>
            <p class="reveal-up delay-400">
              <span data-lang="de">Bei uns geht es nicht nur um Haare. Es geht um das Erlebnis, die Atmosphäre und das Gefühl, als Mann perfekt gepflegt zu sein.</span>
              <span data-lang="ar" class="hidden" dir="rtl">ليس الأمر يتعلق بالشعر فحسب. بل يتعلق بالتجربة، والأجواء، والشعور بأنك رجل مهذب بشكل كامل.</span>
            </p>
          </div>

          <div class="mt-8 md:mt-10 grid grid-cols-2 sm:grid-cols-3 gap-4 md:gap-6">
            <div class="reveal-up delay-200 bg-soran-light/50 p-5 rounded-2xl border border-soran-gold/10 text-center">
              <p class="font-black text-2xl text-soran-gold">1000+</p>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-1">
                <span data-lang="de">Zufriedene Kunden</span>
                <span data-lang="ar" class="hidden" dir="rtl">عميل راضٍ</span>
              </p>
            </div>
            <div class="reveal-up delay-300 bg-soran-light/50 p-5 rounded-2xl border border-soran-gold/10 text-center">
              <p class="font-black text-2xl text-soran-gold">10+</p>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-1">
                <span data-lang="de">Jahre Erfahrung</span>
                <span data-lang="ar" class="hidden" dir="rtl">سنوات خبرة</span>
              </p>
            </div>
            <div class="reveal-up delay-400 bg-soran-light/50 p-5 rounded-2xl border border-soran-gold/10 text-center col-span-2 sm:col-span-1">
              <p class="font-black text-2xl text-soran-gold">★★★★★</p>
              <p class="text-gray-400 text-xs uppercase tracking-wider mt-1">
                <span data-lang="de">Google Bewertung</span>
                <span data-lang="ar" class="hidden" dir="rtl">تقييم جوجل</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Preview Section -->
  <section id="galerie" class="py-16 md:py-28 bg-soran relative">
    <div class="absolute inset-0 bg-pattern opacity-30"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10 md:mb-16">
        <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">
          <span data-lang="de">Einblicke</span>
          <span data-lang="ar" class="hidden" dir="rtl">لمحات</span>
        </span>
        <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-6xl font-black text-white mb-4 tracking-tight leading-tight">
          <span data-lang="de">Unsere <span class="text-gradient">Galerie</span></span>
          <span data-lang="ar" class="hidden" dir="rtl"><span class="text-gradient">معرضنا</span></span>
        </h2>
        <p class="reveal-up delay-200 text-gray-400 max-w-2xl mx-auto text-sm sm:text-base md:text-lg leading-relaxed">
          <span data-lang="de">Eindrücke aus unserem Shop – Atmosphäre, Details und die Kunst des Barbierens.</span>
          <span data-lang="ar" class="hidden" dir="rtl">انطباعات من صالوننا – الأجواء، التفاصيل، وفن الحلاقة.</span>
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
        {galleryImages.map((img, i) => (
          <div class:list={[
            "reveal-up relative aspect-square rounded-2xl overflow-hidden group cursor-pointer",
            i === 0 || i === 3 ? "md:col-span-2 md:row-span-2" : ""
          ]}>
            <div class:list={["w-full h-full flex items-center justify-center transition-transform duration-700 group-hover:scale-110", img.color]}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-soran-gold/30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="absolute inset-0 bg-gradient-to-t from-soran-dark/80 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-4 md:p-6">
              <span class="text-white font-bold text-sm md:text-base">
                <span data-lang="de">{img.altDe}</span>
                <span data-lang="ar" class="hidden" dir="rtl">{img.altAr}</span>
              </span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="py-16 md:py-28 bg-soran-dark relative overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-soran-gold/5 rounded-full blur-3xl"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-10 md:mb-16">
        <span class="reveal-up text-soran-gold text-xs font-bold uppercase tracking-[0.2em] mb-3 block">
          <span data-lang="de">Das sagen unsere Kunden</span>
          <span data-lang="ar" class="hidden" dir="rtl">ماذا يقول عملاؤنا</span>
        </span>
        <h2 class="reveal-up delay-100 text-2xl sm:text-4xl md:text-5xl font-black text-white tracking-tight leading-tight">
          <span data-lang="de"><span class="text-gradient">Bewertungen</span></span>
          <span data-lang="ar" class="hidden" dir="rtl"><span class="text-gradient">التقييمات</span></span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
        {testimonials.map((review, i) => (
          <div class="reveal-up bg-soran-light/30 backdrop-blur-sm rounded-2xl p-6 md:p-8 border border-soran-gold/10 hover:border-soran-gold/20 transition-all duration-300 hover:-translate-y-1">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: review.stars }).map(() => (
                <svg class="w-5 h-5 text-soran-gold" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-300 text-sm leading-relaxed mb-4">
              <span data-lang="de">"{review.textDe}"</span>
