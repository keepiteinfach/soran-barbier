---
import LogoMark from "./LogoMark.astro";

const currentYear = new Date().getFullYear();
---

<footer class="bg-soran border-t border-soran-gold/10">
  <!-- Main Footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Logo & Beschreibung -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <LogoMark class="h-12 w-12 flex-shrink-0" />
          <div>
            <span class="text-soran-gold font-black text-lg uppercase tracking-wider block">SORAN</span>
            <span class="text-gray-400 text-sm">Barbier · Dessau</span>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          Traditionelle Barbierkunst in Dessau-Roßlau. Präzise Schnitte, gepflegte Bärte und die klassische Rasur – mit Stil und Leidenschaft.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="text-lg font-bold mb-6 text-soran-gold">Navigation</h4>
        <ul class="space-y-3">
          <li>
            <a href="/" class="text-gray-400 hover:text-soran-gold transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              Start
            </a>
          </li>
          <li>
            <a href="/#leistungen" class="text-gray-400 hover:text-soran-gold transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              Leistungen
            </a>
          </li>
          <li>
            <a href="/#ueber-uns" class="text-gray-400 hover:text-soran-gold transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              Über uns
            </a>
          </li>
          <li>
            <a href="/#kontakt" class="text-gray-400 hover:text-soran-gold transition-colors flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              Kontakt
            </a>
          </li>
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h4 class="text-lg font-bold mb-6 text-soran-gold">Kontakt</h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-soran-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span class="text-gray-400 text-sm">Zerbster Straße 12<br/>06844 Dessau-Roßlau</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-soran-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <span class="text-gray-400 text-sm">info@soran-barbier.de</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-soran-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span class="text-gray-400 text-sm">0340 - 12345678</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-soran-gold mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-gray-400 text-sm">Mo–Fr: 09:00–18:00<br/>Sa: 09:00–14:00</span>
          </li>
        </ul>

        <!-- Social Links -->
        <div class="flex gap-3 mt-6">
          <a href="#" class="bg-white/5 p-2.5 rounded-lg hover:bg-soran-gold hover:text-soran-dark transition-colors text-gray-400">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="bg-white/5 p-2.5 rounded-lg hover:bg-soran-gold hover:text-soran-dark transition-colors text-gray-400">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-soran-gold/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm text-center md:text-left">
          &copy; {currentYear} SORAN Barbier. Alle Rechte vorbehalten.
        </p>
        <div class="flex items-center gap-6 text-sm">
          <a href="/impressum" class="text-gray-400 hover:text-soran-gold transition-colors">Impressum</a>
          <a href="/datenschutz" class="text-gray-400 hover:text-soran-gold transition-colors">Datenschutz</a>
          <div class="flex items-center gap-2 text-gray-500">
            <span class="w-2 h-2 bg-soran-gold rounded-full animate-pulse"></span>
            Dessau-Roßlau
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
